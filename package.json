{
  "name": "autotable",
  "version": "1.0.0",
  "author": "Paweł Marczewski <pwmarcz@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "parcel index.html",
    "watch": "parcel watch index.html",
    "clean:build": "node scripts/clean-output-dir.mjs build",
    "clean:dist": "node scripts/clean-output-dir.mjs dist",
    "build:react02-assets": "node scripts/build-react02-asset-pack.mjs",
    "build": "npm run clean:build && node ./node_modules/parcel/lib/bin.js build index.html --public-url . --dist-dir build --no-cache",
    "build:web": "npm run clean:dist && node ./node_modules/parcel/lib/bin.js build index.html --public-url /threejsDemo/ --dist-dir dist --no-cache",
    "verify:20x9": "node scripts/verify-20x9.mjs"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@parcel/transformer-image": "2.15.4",
    "@types/events": "^3.0.3",
    "@types/jquery": "^3.5.33",
    "@types/three": "^0.179.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.34.0",
    "parcel": "^2.15.4",
    "playwright-core": "^1.45.0",
    "sharp": "^0.33.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "bootstrap": "^4.4.1",
    "events": "^3.1.0",
    "jquery": "^3.7.1",
    "popper.js": "^1.16.1",
    "three": "^0.179.0"
  }
}
